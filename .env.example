FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
NEXT_PUBLIC_SITE_URL=https://hajia-slay-shop.vercel.app

# Sedifex live catalog sync
# Turn on to pull live catalog from Sedifex.
# On Vercel, add these in Project Settings -> Environment Variables.
SEDIFEX_SYNC_ENABLED=false

# Required when SEDIFEX_SYNC_ENABLED=true
SEDIFEX_BASE_URL=https://api.sedifex.com
SEDIFEX_API_KEY=

# Optional endpoint overrides
SEDIFEX_PRODUCTS_PATH=/products
SEDIFEX_PROMOTIONS_PATH=/promotions

# Optional request timeout in milliseconds
SEDIFEX_TIMEOUT_MS=10000

# Workspace/account scoping (recommended for multi-store Sedifex tenants)
SEDIFEX_WORKSPACE_ID=
SEDIFEX_WORKSPACE_HEADER=x-workspace-id
# Optional: if Sedifex expects workspace in query string, set param name (example: workspace_id)
SEDIFEX_WORKSPACE_QUERY_PARAM=
# Set true to hard-fail when workspace id is missing
SEDIFEX_REQUIRE_WORKSPACE_ID=true
